# ════════════════════════════════════════════════════════════════════════════
#  HOW TO USE
#  ----------
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your real values below (especially DB_URL).
#  3. .env is git-ignored — never commit it.
# ════════════════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
#
#  Format:  postgresql://<user>:<password>@<host>:<port>/<database>
#
#  Examples:
#    Local install:   postgresql://postgres:mypassword@localhost:5432/facelog
#    Remote server:   postgresql://appuser:s3cr3t@192.168.1.50:5432/security_db
#    Supabase:        postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
#    Render / Neon:   paste the connection string from your dashboard directly
#
#  The database must already exist. Run  python main.py setup-db  once to
#  create the tables inside it.
#
DB_URL=postgresql://postgres:yourpassword@localhost:5432/facelog

# ─── Redis ───────────────────────────────────────────────────────────────────
#  Used as the job queue between the camera loop and recognition workers.
#  Local:   redis://localhost:6379/0
#  Remote:  redis://:password@host:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── Camera / Video Source ───────────────────────────────────────────────────
#  0        → default webcam
#  1, 2 … → other webcam indexes
#  /path/to/video.mp4  → video file
#  rtsp://user:pass@192.168.1.x/stream → IP / CCTV camera
CAMERA_SOURCE=0
CAMERA_ID=cam_entry
# Direction this camera records: 'entry' (faces walking in) or 'exit' (faces walking out).
# For a 2-camera setup run two separate processes with different CAMERA_ID and CAMERA_DIRECTION,
# or override per-run with:  python main.py run --camera-id cam_exit --direction exit
CAMERA_DIRECTION=entry

# ── Second camera (optional) ─────────────────────────────────────────────────
# Leave CAMERA_SOURCE2 empty (or remove it) for single-camera / entry-only mode.
# Set it to a webcam index, file path, or RTSP URL to enable exit recording.
# Example: CAMERA_SOURCE2=1   (second USB webcam)
#          CAMERA_SOURCE2=rtsp://user:pass@192.168.1.x/stream2
CAMERA_SOURCE2=
CAMERA_ID2=cam_exit
CAMERA_DIRECTION2=exit

# ─── Recognition ─────────────────────────────────────────────────────────────
# Lower = stricter matching (fewer false positives). Range 0.4 – 0.6.
RECOGNITION_TOLERANCE=0.48
# Minimum seconds before the same person can be re-queued
FACE_QUEUE_COOLDOWN=60

# ─── Workers ─────────────────────────────────────────────────────────────────
# Number of parallel recognition worker processes
WORKER_PROCESSES=2

# ─── Storage ─────────────────────────────────────────────────────────────────
# JPEG compression quality for images stored in DB (1–95)
JPEG_QUALITY=75

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_FILE=logs/facelog.log
